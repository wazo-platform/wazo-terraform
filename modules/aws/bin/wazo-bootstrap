#!/bin/bash -e

function usage() {
    cat << EOF
    This script is used to bootstrap Wazo on AWS

    usage : $(basename $0) [-h]
        without arg : bootstrap wazo
        -h          : setup ha automatically

EOF
    exit 1
}


ha_mode=0

while getopts ':h' opt; do
    case ${opt} in
        h)
            ha_mode=1
            ;;
        *)
            usage
            ;;
    esac
done

shift $((OPTIND-1))

cloud-init status --wait

bash /tmp/wazo-install "$@"

if [ $ha_mode -eq 1 ]; then
    echo "Launching wizard setup"
    python3 /tmp/wazo-wizard
    echo "Done"
    echo "Launching ha configuration"
    python3 /tmp/wazo-configure-ha
    echo "Done"
fi
